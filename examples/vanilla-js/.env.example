# ============================================================
# TON Pay — Vanilla JS Example Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# The browser client reads values injected via <script> globals
# in public/index.html — not this file directly.
# The OPTIONAL webhook server reads these at startup (Node process.env).
# ============================================================

# ------ REQUIRED (dashboard-free path) ------

# Chain: "testnet" | "mainnet"
TONPAY_CHAIN=testnet

# Your TON wallet address (recipient of payments)
TON_RECIPIENT_ADDR=EQ...your_wallet_address

# Your public app URL (used to build the TonConnect manifest URL)
# When testing locally, set this to your ngrok HTTPS URL.
APP_URL=https://your-ngrok-id.ngrok-free.app

# ------ OPTIONAL (webhook-based confirmation) ------
# Only fill these in if you want server-push notifications via the TON Pay
# Merchant Dashboard. The default flow polls pay.ton.org from the client
# and does NOT need these values.

# Your TON Pay API key (from the TON Pay Merchant Dashboard)
# TONPAY_API_KEY=tp_test_xxxxxxxxxxxxxxxx

# Your TON Pay webhook signing secret (from the same dashboard)
# TONPAY_API_SECRET=your_webhook_secret_here

# Port for the optional webhook Express server (default: 3001)
# PORT=3001

# Seed reference for the demo order (used only in local testing)
# DEMO_REFERENCE=demo-ref-001
