# ============================================================
# TON Pay — Vanilla JS Example Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# The webhook server reads these at startup (Node process.env).
# The browser client reads values injected in public/index.html.
# ============================================================

# ------ Webhook server ------
# Your TON Pay webhook signing secret (from the TON Pay dashboard)
TONPAY_API_SECRET=your_webhook_secret_here

# Port for the webhook Express server (default: 3001)
PORT=3001

# Seed reference for the demo order (used only in local testing)
DEMO_REFERENCE=demo-ref-001

# ------ Browser client (inject into index.html <script> block) ------
# Your TON Pay API key
TONPAY_API_KEY=your_api_key_here

# Chain: "testnet" | "mainnet"
TONPAY_CHAIN=testnet

# Your TON wallet address (recipient of payments)
TON_RECIPIENT_ADDR=EQ...your_wallet_address

# Your public app URL (used to build the TonConnect manifest URL)
# When testing locally, set this to your ngrok HTTPS URL
APP_URL=https://your-ngrok-id.ngrok-free.app
