# TON Pay API credentials (testnet)
# Get these from the Merchant Dashboard: https://docs.ton.org/ecosystem/ton-pay/overview
NEXT_PUBLIC_TONPAY_API_KEY=tp_test_xxxxxxxxxxxxxxxxx

# Webhook secret — server-only, never exposed in client bundles
TONPAY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TON recipient address (testnet). Tonkeeper testnet mode will give you one.
NEXT_PUBLIC_TON_RECIPIENT_ADDR=EQ...

# Chain: testnet or mainnet
NEXT_PUBLIC_TONPAY_CHAIN=testnet

# Public URL where this app is reachable (for the tonconnect manifest).
# Use ngrok or similar for local dev.
NEXT_PUBLIC_APP_URL=https://your-ngrok-id.ngrok-free.app
