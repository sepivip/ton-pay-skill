# REQUIRED — your TON recipient address (the wallet that receives funds).
# Tonkeeper Developer Mode → Testnet gives you a testnet address to use here.
NEXT_PUBLIC_TON_RECIPIENT_ADDR=EQ...

# REQUIRED — chain: testnet or mainnet
NEXT_PUBLIC_TONPAY_CHAIN=testnet

# REQUIRED — public URL where this app is reachable (for the tonconnect manifest).
# Use ngrok or similar for local dev.
NEXT_PUBLIC_APP_URL=https://your-ngrok-id.ngrok-free.app

# OPTIONAL — only needed if you opt into webhook-based notifications via the
# TON Pay Merchant Dashboard. The default (dashboard-free) checkout polls
# getTonPayTransferByReference client-side and does NOT need these.
# NEXT_PUBLIC_TONPAY_API_KEY=tp_test_xxxxxxxxxxxxxxxxx
# TONPAY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
